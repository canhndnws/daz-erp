<?xml version="1.0" encoding="UTF-8"?>
<moqui-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/moqui-conf-3.xsd">

    <!--
        RNFP Platform - Root Moqui Configuration
        Loads each module's MoquiConf.xml in dependency order:

          rnfp-common        (no deps)
          rnfp-government    (-> common)
          rnfp-organization  (-> common)
          rnfp-program       (-> common, organization)
          rnfp-learner       (-> common, organization, program)
          rnfp-training-exam (-> common, program, learner)
          rnfp-credential    (-> common, learner, program, organization, training-exam)
          rnfp-api           (-> all)
    -->

    <conf-list>
        <conf location="component://daz-erp/modules/rnfp-common/MoquiConf.xml"/>
        <conf location="component://daz-erp/modules/rnfp-government/MoquiConf.xml"/>
        <conf location="component://daz-erp/modules/rnfp-organization/MoquiConf.xml"/>
        <conf location="component://daz-erp/modules/rnfp-program/MoquiConf.xml"/>
        <conf location="component://daz-erp/modules/rnfp-learner/MoquiConf.xml"/>
        <conf location="component://daz-erp/modules/rnfp-training-exam/MoquiConf.xml"/>
        <conf location="component://daz-erp/modules/rnfp-credential/MoquiConf.xml"/>
        <conf location="component://daz-erp/modules/rnfp-api/MoquiConf.xml"/>
    </conf-list>

</moqui-conf>
