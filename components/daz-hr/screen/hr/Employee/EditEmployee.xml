<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="Edit Employee">

    <parameter name="partyId"/>

    <transition name="updateEmployee">
        <service-call name="mantle.party.PartyServices.update#PartyDetail" in-map="context"/>
        <default-response url="."/>
    </transition>

    <actions>
        <if condition="partyId">
            <service-call name="hr.HrServices.get#Employee" in-map="[partyId:partyId]" out-map="employeeOut"/>
            <set field="person" from="employeeOut.person"/>
            <set field="employee" from="employeeOut.employee"/>
            <set field="employments" from="employeeOut.employments"/>
        </if>
    </actions>

    <widgets>
        <container-row>
            <row-col md="6">
                <container-box>
                    <box-header title="Employee Details - ${person?.firstName} ${person?.lastName}"/>
                    <box-body>
                        <form-single name="EditEmployeeForm" transition="updateEmployee" map="person">
                            <field name="partyId"><default-field><display/></default-field></field>
                            <field name="firstName"><default-field><text-line/></default-field></field>
                            <field name="lastName"><default-field><text-line/></default-field></field>
                            <field name="middleName"><default-field><text-line/></default-field></field>
                            <field name="birthDate"><default-field><date-time type="date"/></default-field></field>
                            <field name="gender">
                                <default-field>
                                    <drop-down allow-empty="true">
                                        <option key="M" text="Male"/>
                                        <option key="F" text="Female"/>
                                    </drop-down>
                                </default-field>
                            </field>
                            <field name="submitButton"><default-field title="Update"><submit/></default-field></field>
                        </form-single>
                    </box-body>
                </container-box>
            </row-col>
            <row-col md="6">
                <container-box>
                    <box-header title="Employment History"/>
                    <box-body>
                        <form-list name="EmploymentList" list="employments" skip-form="true">
                            <field name="employerName"><default-field title="Employer"><display/></default-field></field>
                            <field name="fromDate"><default-field><display/></default-field></field>
                            <field name="thruDate"><default-field><display/></default-field></field>
                            <field name="emplPositionId"><default-field title="Position"><display/></default-field></field>
                        </form-list>
                    </box-body>
                </container-box>
            </row-col>
        </container-row>
    </widgets>
</screen>
