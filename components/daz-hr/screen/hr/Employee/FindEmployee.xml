<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="Find Employees">

    <transition name="editEmployee"><default-response url="../EditEmployee"/></transition>
    <transition name="createEmployee">
        <service-call name="hr.HrServices.create#Employee" in-map="context" out-map="createOut"/>
        <default-response url="../EditEmployee">
            <parameter name="partyId" from="createOut.partyId"/>
        </default-response>
    </transition>

    <actions>
        <service-call name="hr.HrServices.get#Employees" in-map="context" out-map="employeesOut"/>
        <set field="employeeList" from="employeesOut.employeeList"/>
    </actions>

    <widgets>
        <container-row>
            <row-col md="12">
                <container-box>
                    <box-header title="Search Employees"/>
                    <box-toolbar>
                        <container-dialog id="CreateEmployeeDialog" button-text="Create Employee">
                            <form-single name="CreateEmployeeForm" transition="createEmployee">
                                <field name="firstName"><default-field><text-line/></default-field></field>
                                <field name="lastName"><default-field><text-line/></default-field></field>
                                <field name="submitButton"><default-field title="Create"><submit/></default-field></field>
                            </form-single>
                        </container-dialog>
                    </box-toolbar>
                    <box-body>
                        <form-single name="FindEmployeeForm" transition=".">
                            <field name="firstName"><default-field><text-line/></default-field></field>
                            <field name="lastName"><default-field><text-line/></default-field></field>
                            <field name="submitButton"><default-field title="Search"><submit/></default-field></field>
                            <field-layout><field-ref name="firstName"/><field-ref name="lastName"/><field-ref name="submitButton"/></field-layout>
                        </form-single>
                    </box-body>
                </container-box>

                <form-list name="EmployeeList" list="employeeList" skip-form="true">
                    <field name="partyId">
                        <header-field title="ID" show-order-by="true"/>
                        <default-field>
                            <link url="editEmployee" text="${partyId}">
                                <parameter name="partyId"/>
                            </link>
                        </default-field>
                    </field>
                    <field name="firstName">
                        <header-field show-order-by="true"/>
                        <default-field><display/></default-field>
                    </field>
                    <field name="lastName">
                        <header-field show-order-by="true"/>
                        <default-field><display/></default-field>
                    </field>
                    <field name="birthDate">
                        <header-field show-order-by="true"/>
                        <default-field><display/></default-field>
                    </field>
                    <field name="gender">
                        <header-field show-order-by="true"/>
                        <default-field><display/></default-field>
                    </field>
                </form-list>
            </row-col>
        </container-row>
    </widgets>
</screen>
