<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <!--
        Centralized status registry for all RNFP modules.
        All module-level statuses are stored here, discriminated by statusTypeId.

        Usage example:
            statusTypeId="LEARNER_STATUS"    → LRN_ACTIVE, LRN_INACTIVE, LRN_SUSPENDED
            statusTypeId="ENROLLMENT_STATUS" → ENR_IN_PROGRESS, ENR_COMPLETED, ENR_DROPPED
            statusTypeId="CENTER_STATUS"     → CTR_PENDING, CTR_ACCREDITED, CTR_SUSPENDED, CTR_REVOKED
            statusTypeId="EXAM_RESULT"       → EXAM_PASS, EXAM_FAIL, EXAM_ABSENT
            statusTypeId="CREDENTIAL_STATUS" → CRED_ISSUED, CRED_REVOKED
            statusTypeId="DOCUMENT_STATUS"   → DOC_ACTIVE, DOC_ARCHIVED, DOC_REVOKED
            statusTypeId="PROVINCE_STATUS"   → PROV_ACTIVE, PROV_INACTIVE
            statusTypeId="PROGRAM_STATUS"    → PROG_ACTIVE, PROG_INACTIVE
            statusTypeId="CP_AUTH_STATUS"    → CP_AUTHORIZED, CP_PENDING, CP_REVOKED
    -->

    <!-- ========== Status Type ========== -->
    <entity entity-name="StatusType" package="rnfp.common" short-alias="StatusType">
        <description>Grouping of status values (e.g., LEARNER_STATUS, ENROLLMENT_STATUS)</description>
        <field name="statusTypeId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
    </entity>

    <!-- ========== Status Item ========== -->
    <entity entity-name="StatusItem" package="rnfp.common" short-alias="StatusItem">
        <description>Centralized lookup table for all RNFP status values, grouped by type.</description>
        <field name="statusId" type="id" is-pk="true"/>
        <field name="statusTypeId" type="id" not-null="true"/>
        <field name="statusCode" type="text-short">
            <description>Short machine-readable code (same as statusId by convention)</description>
        </field>
        <field name="description" type="text-medium" not-null="true"/>
        <field name="sequenceNum" type="number-integer" default="10">
            <description>Display order within a status type</description>
        </field>

        <relationship type="one" related="rnfp.common.StatusType" short-alias="statusType">
            <key-map field-name="statusTypeId"/>
        </relationship>

        <index name="STATUS_TYPE_IDX">
            <index-field name="statusTypeId"/>
        </index>
    </entity>

</entities>
